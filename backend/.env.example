# Copy this file to `.env` and fill in real values. `.env` is gitignored —
# never commit real secrets. Rotate any credential that has ever been committed.

# ─── PostgreSQL (used by the db container and the backend) ──────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=robotfleet

# Full connection string (must match the POSTGRES_* values above).
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:change-me-strong-password@db:5432/robotfleet

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# Telemetry ingestion buffer (Redis Streams). Set false to write straight to DB.
USE_REDIS_BUFFER=true

# ─── App secrets ────────────────────────────────────────────────────
# Shared key required on the X-API-Key header for telemetry/command endpoints.
TELEMETRY_API_KEY=change-me-random-api-key

# ─── Application ────────────────────────────────────────────────────
# Environment: development | staging | production
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── CORS ───────────────────────────────────────────────────────────
# Comma-separated allowed origins (use * only in development)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ──────────────────────────────────────────────────
# Max telemetry POSTs per IP per minute
RATE_LIMIT_PER_MINUTE=120
