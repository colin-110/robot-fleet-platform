# ── Backend API ──────────────────────────────────────────────────────
# Leave empty to use relative URLs (same-origin), or set an absolute URL
# for cross-origin setups (e.g. backend on a different port/host).
VITE_API_BASE_URL=

# ── WebSocket Authentication ─────────────────────────────────────────
# API key used for WebSocket connection authentication.
# Must match the backend TELEMETRY_API_KEY value.
VITE_WS_API_KEY=your-api-key-here
