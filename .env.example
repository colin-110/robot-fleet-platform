# PostgreSQL credentials for local DB container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=robotfleet
DATABASE_URL=postgresql://postgres:postgres@db:5432/robotfleet

# Redis URL
REDIS_URL=redis://redis:6379/0

# App Secrets
# REPLACE THIS WITH A REAL SECRET IN PRODUCTION
TELEMETRY_API_KEY=replace-me-in-production
